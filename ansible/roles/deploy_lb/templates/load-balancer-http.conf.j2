upstream app_hosts {
    {% for host in groups['appserver'] %}
    server {{ host }}:8000 max_fails=3 fail_timeout=10s;
    {% endfor %}
}

server {
    listen 80;
    server_name osay21.me www.osay21.me;

    location / {
        proxy_pass http://app_hosts;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}